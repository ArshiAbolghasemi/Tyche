# ── Tyche configuration — copy to .env and edit ──────────────────────────────
# Every value has a sensible default; only override what you need. Lists are
# comma-separated (or a JSON array). Booleans: 1/true/yes/on.

# Deployment profile: development | staging | production
TYCHE_ENV=development

# HuggingFace — REQUIRED for scoring via the InferenceClient
HF_TOKEN=

# ── Paths ────────────────────────────────────────────────────────────────────
TYCHE_PATHS_INPUT=data/eodhd/news.csv
TYCHE_PATHS_OUTPUT=data/output/news_sentiment.parquet

# ── Ingest ───────────────────────────────────────────────────────────────────
TYCHE_INGEST_GROUP_KEY_COLS=exchange,type
TYCHE_INGEST_MASKED_PLACEHOLDER=the company

# ── Segmentation ─────────────────────────────────────────────────────────────
TYCHE_SEGMENTATION_CLAUSE_DELIMITERS=;,," and "," but "," because "," although "," however "
# JSON array form also accepted:
# TYCHE_SEGMENTATION_FINANCIAL_VOCAB=["revenue","profit","loss","eps",...]
TYCHE_SEGMENTATION_FINANCIAL_VOCAB=revenue,revenues,earnings,profit,loss,income,eps,ebitda,margin,guidance,outlook,dividend,acquisition,merger,deal,growth,decline,surge,drop,beat,miss,forecast,estimate,quarter,fiscal,stock,share,shares,market,price,target,upgrade,downgrade,buy,sell,hold,bullish,bearish

# ── Model (ProsusAI/finbert via HF InferenceClient) ──────────────────────────
TYCHE_MODEL_NAME=ProsusAI/finbert
TYCHE_MODEL_REVISION=main
TYCHE_MODEL_EXPECTED_LABELS=positive,negative,neutral
TYCHE_MODEL_MAX_TOKENS=512
TYCHE_MODEL_BATCH_SIZE=32
TYCHE_MODEL_DEVICE=cpu
TYCHE_MODEL_PROVIDER=hf-inference

# ── Aggregation ──────────────────────────────────────────────────────────────
TYCHE_AGGREGATION_POSITION_LAMBDA=1.5
TYCHE_AGGREGATION_IRRELEVANT_DISCOUNT=0.3
TYCHE_AGGREGATION_WEIGHT_EPSILON=0.000001

# ── Neutralizer ──────────────────────────────────────────────────────────────
TYCHE_NEUTRALIZER_ENTITY_PRIOR_PATH=data/output/entity_prior.json
TYCHE_NEUTRALIZER_ROLLING_WINDOW_DAYS=60
TYCHE_NEUTRALIZER_MIN_EVENTS=10
TYCHE_NEUTRALIZER_SHRINKAGE_K=20.0
TYCHE_NEUTRALIZER_WINSOR_LO=0.01
TYCHE_NEUTRALIZER_WINSOR_HI=0.99
TYCHE_NEUTRALIZER_STD_FLOOR=0.000001
TYCHE_NEUTRALIZER_GROUP_MIN_MEMBERS=3

# ── Auditor ──────────────────────────────────────────────────────────────────
TYCHE_AUDITOR_BASELINE_PATH=data/output/baseline.json
TYCHE_AUDITOR_PSI_THRESHOLD=0.10
TYCHE_AUDITOR_SAME_SIGN_ALERT=0.80
# JSON array of {text, expect} where expect ∈ {pos, neg, neu}
TYCHE_AUDITOR_SANITY_SENTENCES=[{"text":"revenues increased significantly","expect":"pos"},{"text":"the company reported a loss","expect":"neg"},{"text":"the meeting was held on Tuesday","expect":"neu"},{"text":"profit beat expectations and the stock surged","expect":"pos"},{"text":"shares tumbled after the profit warning","expect":"neg"}]

# ── Dask ─────────────────────────────────────────────────────────────────────
TYCHE_DASK_BLOCKSIZE=128MB
TYCHE_DASK_NPARTITIONS=4
